AWS_REGION=ap-northeast-2

# Names of the two Lambda functions created in the AWS console
DISK_FUNCTION_NAME=lambda-disk-v1
NETWORK_FUNCTION_NAME=lambda-network-v1

# Pilot matrix
MEMORY_SIZES=128,512,1769
CONCURRENCIES=1,5,10
ROUNDS=5

# Synchronization and round validation
BARRIER_SECONDS=10
ROUND_GAP_SECONDS=5
MAX_START_LAG_MS=250

# Lambda configuration automatically applied by the runner
LAMBDA_TIMEOUT_SECONDS=300
EPHEMERAL_STORAGE_MB=1024

# Disk defaults
DISK_MODE=buffered
DISK_SIZE_MB=128
DISK_BLOCK_KB=1024

# Network defaults
# Never commit the real IP/URL. Multiple URLs may be comma-separated.
NETWORK_URLS=http://YOUR_EC2_PUBLIC_IP/test100M.bin
NETWORK_EXPECTED_SIZE_MB=100
NETWORK_TIMEOUT_SECONDS=180
NETWORK_CHUNK_KB=1024
